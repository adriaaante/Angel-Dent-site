# Конфиг для scripts/deploy.sh — заливка статики и Telegram-конфига
# на хостинг reg.ru. Скопируйте этот файл в scripts/.deploy.env
# и заполните. scripts/.deploy.env в .gitignore — в репо не коммитится.

# ssh — лучший вариант, если у тарифа reg.ru включён SSH (rsync,
#       шлёт только дельту, в разы быстрее).
# sftp — если SSH-доступа нет, но есть SFTP.
# ftp  — самый дешёвый тариф, без шифрования. Не рекомендуется.
DEPLOY_PROTO=ssh

# Адрес хостинга. Для SSH/SFTP обычно <server>.hosting.reg.ru,
# для FTP — ftp.<домен> или то же самое.
REG_HOST=

# Порт: 22 для ssh/sftp, 21 для ftp. Можно опустить — подставится
# дефолт под выбранный протокол.
REG_PORT=

# Логин (что-то вроде u1234567).
REG_USER=

# Пароль. Для SSH с ключами можно не заполнять, тогда rsync будет
# дёргать ssh-agent / ~/.ssh/id_*.
REG_PASS=

# Абсолютный путь к корню сайта на хостинге. На reg.ru обычно вида
# /var/www/<USER>/data/www/<домен> — точный путь видно в файловом
# менеджере панели или в свойствах FTP-аккаунта.
REG_PATH=

# --- Telegram bot (для api/config.php на сервере) ---
# Скрипт деплоя возьмёт эти значения и сгенерирует api/config.php
# локально, потом зальёт на хостинг. Сам api/config.php в .gitignore.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-5176309139
